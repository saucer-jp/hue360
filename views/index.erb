<!DOCTYPE HTML>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <title>[ HUE / 360 ] The Color Scheme Application</title>
  <link rel="stylesheet" href="//yui.yahooapis.com/3.5.1/build/cssreset/cssreset-min.css">    
  <link rel="stylesheet" href="//yui.yahooapis.com/3.5.1/build/cssfonts/cssfonts-min.css">
  <!--
  <link rel="stylesheet" href="http://yui.yahooapis.com/3.5.1/build/cssbase/cssbase-min.css">
  -->
  <link href='//fonts.googleapis.com/css?family=Oswald:300,400,700' rel='stylesheet' type='text/css'>
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <div id="controller">
    <h1>Circle Controller</h1>
    <nav>
      <div class="circle-conf">
        <h2>Color Space</h2>
        <select id="colorSpace">
          <option value="munsell" selected="selected">Munsell</option>
          <option value="rgb">RGB</option>
          <option value="rgb+">RGB+</option>
        </select>
      </div>
      <div class="circle-conf">
        <h2>Hue Step</h2>
        <select id="hueStep">
          <option value="10">10</option>
          <option value="20" selected="selected">20</option>
          <option value="30">30</option>
          <option value="40">40</option>
          <option value="50">50</option>
          <option value="100">100</option>
        </select>
      </div>
      <div class="circle-conf">
        <h2>Chroma Step</h2>
        <select id="chromaStep">
          <option value="3">3</option>
          <option value="4">4</option>
          <option value="5">5</option>
          <option value="6">6</option>
          <option value="7" selected="selected">7</option>
          <option value="8">8</option>
          <option value="9">9</option>
          <option value="10">10</option>
        </select>
      </div>
      <div class="circle-conf">
        <h2>Judge</h2>
        <select id="judge">
          <option value="true" selected="selected">ON</option>
          <option value="false">OFF</option>
        </select>
      </div>
      <div class="circle-conf">
        <h2>Change background-color = shift + color chip click</h2>
      </div>
      <!--
      <div class="circle-conf">
        <h2>Background Color</h2>
        <select id="BGColor">
          <option value="#fff" selected="selected">#FFFFFF</option>
          <option value="#eee">#EEEEEE</option>
          <option value="#ddd">#DDDDDD</option>
          <option value="#ccc">#CCCCCC</option>
          <option value="#bbb">#BBBBBB</option>
          <option value="#aaa">#AAAAAA</option>
          <option value="#999">#999999</option>
          <option value="#888">#888888</option>
          <option value="#777">#777777</option>
          <option value="#666">#666666</option>
          <option value="#555">#555555</option>
          <option value="#444">#444444</option>
          <option value="#333">#333333</option>
          <option value="#222">#222222</option>
          <option value="#111">#111111</option>
          <option value="#000">#000000</option>
        </select>
      </div>
      -->
    </nav>
  </div>
  <div id="userColor"></div>
  <div id="colorCircle">
    <ul id="brightness">
      <li class="chip chip1 white-chip current-brightness"></li>
      <li class="chip chip2"></li>
      <li class="chip chip3"></li>
      <li class="chip chip4"></li>
      <li class="chip chip5"></li>
      <li class="chip chip6"></li>
      <li class="chip chip7"></li>
      <li class="chip chip8"></li>
      <li class="chip chip9"></li>
      <li class="chip chip10"></li>
    </ul>
  </div>
  <div id="print"></div>
  <span id="title">HUE/360</span>
  <small id="copyright">&copy; 2012 <a href="http://saucer.jp" class="saucer-web">SAUCER.JP</a></small>

  <script type="text/javascript" src="//ajax.googleapis.com/ajax/libs/jquery/1.8.2/jquery.min.js"></script>
  <script>
    window.jQuery || document.write( '<script type="text/javascript" src="/js/jquery.min.js"><\/script>' )
  </script>
  <script type="text/javascript" src="/js/color-circle.js"></script>
  <script type="text/javascript" src="/js/app.js"></script>
</body>
</html>
